# Glorri Jobs Scraper Configuration
# Copy this file to .env and fill in your values

# Base URL for scraping
BASE_URL=https://jobs.glorri.az/

# Second website for scraping (jobsearch.az)
JOBSEARCH_BASE_URL=https://jobsearch.az/

# Telegram Bot Configuration
# Get your bot token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Chat ID where notifications will be sent
# Can be a channel (@channel_name) or chat ID (123456789)
TELEGRAM_CHAT_ID=your_chat_id_here

# Keyword filter — only send Telegram notifications for jobs whose
# title, description, or requirements contain at least one keyword.
# Comma-separated, case-insensitive.  Leave empty to send all jobs.
TELEGRAM_KEYWORDS=Python,SQL

# Delay between consecutive Telegram messages (seconds).
# Increase this if you hit "Flood control exceeded" errors.
# Private chats: 2-3 s recommended.  Groups/channels: 1 s is usually fine.
TELEGRAM_MESSAGE_DELAY=3.0
